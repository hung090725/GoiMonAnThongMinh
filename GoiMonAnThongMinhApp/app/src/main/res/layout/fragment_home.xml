<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:orientation="vertical"
    android:paddingHorizontal="22dp"
    android:paddingTop="22dp">

    <TextView
        android:id="@+id/textHomeHello"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/home_hello"
        android:textColor="@color/primary_green"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textHomeQuestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/home_question"
        android:textColor="@color/text_main"
        android:textSize="27sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/cardMealMindIntro"
        android:layout_width="match_parent"
        android:layout_height="164dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_fragment_accent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/home_intro_title"
                android:textColor="@color/text_main"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="2dp"
                android:text="@string/home_intro_desc"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonOpenSmartChat"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginTop="12dp"
                android:minWidth="0dp"
                android:paddingHorizontal="16dp"
                android:text="@string/smart_chat_open"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:backgroundTint="@color/primary_green"
                app:cornerRadius="18dp" />
        </LinearLayout>

        <ImageView
            android:layout_width="74dp"
            android:layout_height="74dp"
            android:layout_marginStart="12dp"
            android:contentDescription="@string/home_intro_title"
            android:src="@drawable/ic_meal_placeholder" />
    </LinearLayout>

    <TextView
        android:id="@+id/textRecipeSectionTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="@string/home_recipe_section"
        android:textColor="@color/text_main"
        android:textSize="20sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/layoutHomeScrollActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/buttonHomeScrollTop"
            style="@style/TextAppearance.MealMind.RecipeChip"
            android:background="@drawable/bg_recipe_chip"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:text="Đầu danh sách" />

        <TextView
            android:id="@+id/buttonHomeScrollBottom"
            style="@style/TextAppearance.MealMind.RecipeChip"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_recipe_chip_orange"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:text="Cuối danh sách" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressRecipes"
        style="?android:attr/progressBarStyle"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="34dp"
        android:indeterminateTint="@color/accent_orange" />

    <TextView
        android:id="@+id/textEmptyRecipes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
        android:gravity="center"
        android:text="@string/home_empty_recipes"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/textErrorRecipes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
        android:gravity="center"
        android:text="@string/home_error_recipes"
        android:textColor="@color/accent_orange"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerRecipes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="104dp"
        android:scrollbars="vertical"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
</LinearLayout>
