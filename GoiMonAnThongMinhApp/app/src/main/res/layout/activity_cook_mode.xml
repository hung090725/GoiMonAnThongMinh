<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="132dp"
            android:background="@color/primary_green"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="18dp"
            android:paddingTop="18dp">

            <ImageButton
                android:id="@+id/buttonCookBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_chip_green_soft"
                android:contentDescription="@string/recipe_detail_title"
                android:padding="11dp"
                android:src="@drawable/ic_back_dark"
                app:tint="@color/primary_green_dark" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textCookRecipeName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Cook Mode"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textCookProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Bước 1/1"
                    android:textColor="@color/primary_light"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:id="@+id/textCookStep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_fragment_card"
                android:gravity="center"
                android:lineSpacingExtra="6dp"
                android:minHeight="220dp"
                android:padding="24dp"
                android:text="Đang tải bước nấu..."
                android:textColor="@color/text_primary"
                android:textSize="23sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textCookTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:text="05:00"
                android:textColor="@color/accent_orange"
                android:textSize="32sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonCookTimerStart"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Bắt đầu 5 phút"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:backgroundTint="@color/accent_orange"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonCookTimerReset"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="Đặt lại"
                    android:textAllCaps="false"
                    android:textColor="@color/primary_green"
                    app:backgroundTint="@color/primary_light"
                    app:cornerRadius="16dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="18dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCookPrev"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:text="Bước trước"
                android:textAllCaps="false"
                android:textColor="@color/primary_green"
                app:backgroundTint="@color/white"
                app:cornerRadius="16dp"
                app:strokeColor="@color/primary_green"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCookNext"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="Bước tiếp"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:backgroundTint="@color/primary_green"
                app:cornerRadius="16dp" />
        </LinearLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressCookMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/primary_green"
        android:visibility="gone" />
</FrameLayout>
