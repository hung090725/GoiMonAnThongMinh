<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="18dp"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/textHistoryTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hôm nay"
            android:textColor="@color/primary_green"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textHistoryInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tôi có trứng, cà chua"
            android:textColor="@color/text_main"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textHistoryResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            android:text="MealMind AI đã gợi ý món phù hợp..."
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textOpenHistoryRecipe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_recipe_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="Mở món gợi ý"
                android:textColor="@color/primary_green"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textDeleteHistory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_recipe_chip_orange"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="Xóa"
                android:textColor="@color/accent_orange"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
