<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:background="@drawable/bg_recipe_image_placeholder">

            <ImageView
                android:id="@+id/imageRecipe"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_recipe_image_placeholder"
                android:contentDescription="@string/recipe_image_content"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_meal_placeholder" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/textRecipeName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_main"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textRecipeDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:lineSpacingExtra="2dp"
                android:maxLines="2"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textCalories"
                        style="@style/TextAppearance.MealMind.RecipeChip"
                        android:background="@drawable/bg_recipe_chip" />

                    <TextView
                        android:id="@+id/textCost"
                        style="@style/TextAppearance.MealMind.RecipeChip"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_recipe_chip_orange" />

                    <TextView
                        android:id="@+id/textCookingTime"
                        style="@style/TextAppearance.MealMind.RecipeChip"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_recipe_chip" />

                    <TextView
                        android:id="@+id/textDifficulty"
                        style="@style/TextAppearance.MealMind.RecipeChip"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_recipe_chip_orange" />
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
