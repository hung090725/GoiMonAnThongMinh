<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="148dp"
            android:background="@color/primary_green"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="18dp"
            android:paddingTop="18dp">

            <ImageButton
                android:id="@+id/buttonHistoryBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_chip_green_soft"
                android:contentDescription="@string/recipe_detail_title"
                android:padding="11dp"
                android:src="@drawable/ic_back_dark"
                app:tint="@color/primary_green_dark" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lịch sử gợi ý"
                    android:textColor="@color/white"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Xem lại câu hỏi và món MealMind AI đã đề xuất"
                    android:textColor="@color/primary_light"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerAiHistory"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="24dp"
            android:scrollbars="vertical" />

        <LinearLayout
            android:id="@+id/layoutAiHistoryState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="34dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="92dp"
                android:layout_height="92dp"
                android:src="@drawable/ic_nav_search"
                app:tint="@color/divider_soft" />

            <TextView
                android:id="@+id/textAiHistoryState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="Chưa có lịch sử gợi ý"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressAiHistory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/primary_green"
        android:visibility="gone" />
</FrameLayout>
