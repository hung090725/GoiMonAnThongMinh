<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.MealMindAI" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryDark">@color/primary_green_dark</item>
        <item name="colorSecondary">@color/accent_orange</item>
        <item name="colorAccent">@color/accent_orange</item>
        <item name="android:colorAccent">@color/accent_orange</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:windowBackground">@color/auth_background</item>
        <item name="android:statusBarColor">@color/auth_mint_background</item>
        <item name="android:navigationBarColor">@color/auth_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.MealMindAI" parent="Base.Theme.MealMindAI" />

    <style name="Theme.MealMindAI.Preview" parent="Base.Theme.MealMindAI" />

    <style name="Widget.MealMind.BottomNavigation.ActiveIndicator" parent="">
        <item name="android:color">@color/accent_orange_soft</item>
    </style>

    <style name="TextAppearance.MealMind.BottomNav.Active" parent="">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.MealMind.BottomNav.Inactive" parent="">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.MealMind.RecipeChip" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textColor">@color/primary_green</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
